# ===== Server-side secrets (DO NOT COMMIT .env) =====

# DeepSeek API Key
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Proxy server port
PROXY_PORT=3001

# ===== Frontend-exposed vars (VITE_ prefix will be bundled) =====

# Force mock mode (true/false)
VITE_USE_MOCK=false
